  "description": "Offline, explainable heuristics for spotting AI-generated code patterns in a codebase.",
  "type": "module",
  "bin": {
    "check-ai-slop": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byigitt/check-ai-slop.git"
  },
  "bugs": {
